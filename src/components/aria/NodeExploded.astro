<style>
  .explode {
    display: grid;
    grid-template-columns: 1.25fr 1fr;
    gap: 2.5rem;
    align-items: center;
    margin-top: 2.5rem;
    background: var(--paper-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 2rem;
  }
  .explode-stage svg { width: 100%; height: auto; display: block; }
  .explode-labels {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .explode-labels li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.92rem;
  }
  .x-chip {
    flex: none;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
  }
  @media (max-width: 800px) {
    .explode { grid-template-columns: 1fr; padding: 1.25rem; }
    .explode-labels { grid-template-columns: 1fr 1fr; gap: 0.45rem; }
    .explode-labels li { font-size: 0.8rem; }
    .x-chip { width: 22px; height: 22px; font-size: 0.65rem; }
  }
</style>

<script>
  import { gsap } from '../../lib/motion';

  const root = document.getElementById('explode');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (root && !reduced) {
    const collapsed: Array<[string, number]> = [
      ['#g-lid', 158],
      ['#g-parts-a', 110],
      ['#g-parts-b', 84],
      ['#g-pcb', 50],
    ];
    collapsed.forEach(([sel, y]) => gsap.set(sel, { y }));
    gsap.set('.explode-labels li', { opacity: 0.15, x: 16 });
    gsap.set('.x-dot', { opacity: 0 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: 'top 15%',
        end: '+=130%',
        pin: true,
        scrub: 0.8,
      },
    });
    collapsed.forEach(([sel]) => tl.to(sel, { y: 0, ease: 'none', duration: 1 }, 0));
    tl.to('.x-dot', { opacity: 1, duration: 0.25, stagger: 0.035 }, 0.45);
    tl.to('.explode-labels li', { opacity: 1, x: 0, duration: 0.25, stagger: 0.045 }, 0.4);
  }
</script>
