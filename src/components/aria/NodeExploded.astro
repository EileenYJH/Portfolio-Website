---
const labels = [
  { n: '01', t: 'Ventilated case — top', x: 53, y: 15 },
  { n: '02', t: 'MQ-2 — smoke & combustibles', x: 29, y: 32 },
  { n: '03', t: 'MQ-7 — carbon monoxide', x: 56, y: 37 },
  { n: '04', t: 'MQ-135 — air quality', x: 67, y: 69 },
  { n: '05', t: 'SOS button (red)', x: 19, y: 40 },
  { n: '06', t: 'Active buzzer', x: 46.5, y: 40.5 },
  { n: '07', t: 'Alert LEDs + 220 Ω resistor', x: 63, y: 44.5 },
  { n: '08', t: 'ESP32 dev board — the brain', x: 55, y: 52.5 },
  { n: '09', t: 'DHT11 — temperature & humidity', x: 45, y: 64 },
  { n: '10', t: 'IR flame sensor', x: 17, y: 53 },
  { n: '11', t: 'Push button (white) — test', x: 29, y: 60 },
  { n: '12', t: 'Perforated PCB', x: 22, y: 68 },
  { n: '13', t: 'Ventilated case — bottom', x: 46, y: 83 },
];
---
<div class="explode" id="explode">
  <div class="explode-stage">
    <div class="photo-frame">
      <img
        id="img-exploded"
        src="/images/aria/node-exploded.jpg"
        alt="Exploded render of an ARIA sensor node: ventilated lid, gas sensors, buttons, buzzer, LEDs, ESP32 board, DHT11, IR flame sensor, perforated PCB, and case bottom."
        width="640"
        height="960"
        loading="lazy"
      />
      <img
        id="img-assembled"
        src="/images/aria/node-assembled.jpg"
        alt="Assembled ARIA sensor node in its ventilated case, top view, 90 by 120 by 45 millimetres."
        width="620"
        height="680"
        loading="lazy"
      />
      {labels.map((l) => (
        <span class="x-dot" style={`left: ${l.x}%; top: ${l.y}%;`}>{l.n}</span>
      ))}
    </div>
  </div>
  <ol class="explode-labels">
    {labels.map((l) => (
      <li><span class="x-chip">{l.n}</span>{l.t}</li>
    ))}
  </ol>
</div>

<style>
  .explode {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 2.5rem;
    align-items: center;
    margin-top: 2.5rem;
    background: var(--paper-raised);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.5rem;
  }
  .photo-frame {
    position: relative;
    height: min(70vh, 620px);
    aspect-ratio: 640 / 960;
    margin-inline: auto;
    background: #353535;
    border-radius: calc(var(--radius) - 4px);
    overflow: hidden;
  }
  .photo-frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  #img-assembled { opacity: 0; }
  .x-dot {
    position: absolute;
    transform: translate(-50%, -50%);
    width: 24px;
    height: 24px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--accent);
    border: 2px solid #FFFFFF;
    color: #FFFFFF;
    font-size: 0.68rem;
    font-weight: 600;
    line-height: 1;
  }
  .explode-labels {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.5rem;
  }
  .explode-labels li {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.92rem;
  }
  .x-chip {
    flex: none;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-soft);
    color: var(--accent);
    font-size: 0.72rem;
    font-weight: 600;
  }
  @media (max-width: 800px) {
    .explode { grid-template-columns: 1fr; padding: 1rem; }
    .photo-frame { height: auto; width: 100%; max-width: 420px; }
    .explode-labels { grid-template-columns: 1fr 1fr; gap: 0.45rem; }
    .explode-labels li { font-size: 0.8rem; }
    .x-chip { width: 22px; height: 22px; font-size: 0.65rem; }
    .x-dot { width: 20px; height: 20px; font-size: 0.6rem; }
  }
</style>

<script>
  import { gsap } from '../../lib/motion';

  const root = document.getElementById('explode');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (root && !reduced) {
    gsap.set('#img-assembled', { opacity: 1 });
    gsap.set('#img-exploded', { opacity: 0, scale: 0.96 });
    gsap.set('.x-dot', { opacity: 0, scale: 0.4 });
    gsap.set('.explode-labels li', { opacity: 0.15, x: 16 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: root,
        start: 'top 10%',
        end: '+=160%',
        pin: true,
        scrub: 0.8,
      },
    });
    tl.to('#img-assembled', { opacity: 0, duration: 0.35, ease: 'none' }, 0.12)
      .to('#img-exploded', { opacity: 1, scale: 1, duration: 0.4, ease: 'none' }, 0.14)
      .to('.x-dot', { opacity: 1, scale: 1, duration: 0.18, stagger: 0.04 }, 0.55)
      .to('.explode-labels li', { opacity: 1, x: 0, duration: 0.22, stagger: 0.045 }, 0.52);
  }
</script>
