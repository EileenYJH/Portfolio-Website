  { n: '03', t: 'MQ-7 — carbon monoxide' },
  { n: '04', t: 'MQ-135 — air quality' },
  { n: '05', t: 'SOS button (red)' },
  { n: '06', t: 'Active buzzer' },
  { n: '07', t: 'Alert LEDs + 220 Ω resistor' },
  { n: '08', t: 'ESP32 dev board — the brain' },
  { n: '09', t: 'DHT11 — temperature & humidity' },
  { n: '10', t: 'IR flame sensor' },
  { n: '11', t: 'Push button (white) — test' },
