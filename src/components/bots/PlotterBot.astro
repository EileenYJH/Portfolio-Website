<div class="plotter" aria-hidden="true">
  <svg viewBox="0 0 600 44" fill="none">
    <line id="plot-line" x1="4" y1="38" x2="560" y2="38" stroke="#1D4ED8" stroke-width="3" stroke-linecap="round" />
    <g id="plot-car" transform="translate(560,0)">
      <rect x="-16" y="4" width="32" height="18" rx="6" fill="#14181F" />
      <circle cx="8" cy="13" r="3" fill="#2563EB" />
      <rect x="-2" y="22" width="4" height="12" rx="2" fill="#3B4554" />
      <path d="M0 34 l-3 -5 h6 z" fill="#1D4ED8" />
    </g>
  </svg>
</div>

<style>
  .plotter { width: min(420px, 70%); margin-top: 0.6rem; }
  .plotter svg { width: 100%; height: auto; display: block; }
</style>

<script>
  import { gsap, ScrollTrigger } from '../../lib/motion';

  const line = document.getElementById('plot-line');
  const car = document.getElementById('plot-car');
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (line && car && !reduced) {
    gsap.set(line, { attr: { x2: 4 } });
    gsap.set(car, { attr: { transform: 'translate(4,0)' } });
    const tl = gsap.timeline({
      scrollTrigger: { trigger: '.plotter', start: 'top 92%', once: true },
      defaults: { duration: 1.5, ease: 'power2.inOut' },
    });
    tl.to(line, { attr: { x2: 560 } }, 0).to(car, { attr: { transform: 'translate(560,0)' } }, 0);
  }
</script>
